{
  "name": "agenda-inteligente-backend",
  "version": "1.0.0",
  "description": "Backend API - Ordin Flow",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "postinstall": "prisma generate",
    "start": "node dist/index.js",
    "db:generate": "tsx scripts/run-prisma.ts generate",
    "db:push": "tsx scripts/run-prisma.ts db push",
    "db:migrate": "tsx scripts/run-prisma.ts migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "tsx scripts/run-prisma.ts studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@google/generative-ai": "^0.24.0",
    "@prisma/client": "^6.8.2",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.6.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "form-data": "^4.0.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.0",
    "prisma": "^6.8.2",
    "zod": "^3.25.28"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/form-data": "^2.5.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
