# Server
PORT=3100
NODE_ENV=production

# Database (variáveis individuais — DATABASE_URL é montada automaticamente)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=ordin
DATABASE_PASSWORD=altere-sua-senha-aqui
DATABASE_NAME=ordin
DATABASE_SCHEMA=public

# Alternativa: informar DATABASE_URL completa (usada apenas se NENHUMA variável individual estiver definida)
# DATABASE_URL=postgresql://ordin:senha@localhost:5432/ordin?schema=public

# JWT (mínimo 32 caracteres — gere valores únicos em produção)
JWT_SECRET=altere-este-segredo-jwt-com-pelo-menos-32-chars
JWT_REFRESH_SECRET=altere-este-segredo-refresh-com-pelo-menos-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Criptografia das configurações do sistema (obrigatório — permanece no .env)
SETTINGS_ENCRYPTION_KEY=altere-esta-chave-de-criptografia-com-32-chars-minimo

# E-mail promovido a ADMIN no login/registro (opcional)
# ADMIN_BOOTSTRAP_EMAIL=admin@suaempresa.com

# Google Gemini — opcional após migrar para o painel admin (Configurações do Sistema)
GEMINI_API_KEY=sua-chave-gemini
GEMINI_MODEL=gemini-2.0-flash

# Whisper local (Speech-to-Text — serviço Python em services/stt/)
# STT_PROVIDER: provedor de transcrição (atualmente apenas "local")
STT_PROVIDER=local
# STT_SERVICE_URL: URL do serviço FastAPI/Whisper (PM2: whisper-stt)
STT_SERVICE_URL=http://localhost:8001
STT_TIMEOUT_MS=120000
# STT_PORT: porta usada pelo start.sh (deve coincidir com STT_SERVICE_URL)
STT_PORT=8001
# WHISPER_MODEL: tiny | base | small | medium | large-v2 | large-v3
WHISPER_MODEL=small
# WHISPER_LANGUAGE: código ISO (pt, en) ou "auto"
WHISPER_LANGUAGE=pt

# Cloudinary (opcional — sem configurar, arquivos ficam em uploads/ local)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS (domínios permitidos, separados por vírgula, ou * para todos)
CORS_ORIGIN=*
